# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenvs / tooling caches
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets / local env (never commit — secrets come via SecretStore at runtime)
.env
*.local.yaml

# Transient media (raw audio/video has short/no retention — DESIGN §10)
*.tmp
/tmp/
**/_media_tmp/
# Generated by google-github-actions/auth
gha-creds-*.json

# Terraform — local state, plans, and tfvars (state may hold sensitive values; tfvars hold IDs)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
infra/**/terraform.tfvars

# Full transitive dependency lock (regenerate per environment — see docs/DEPENDENCY-MANAGEMENT.md)
constraints.lock.txt

# Local basic UI runtime data
apps/blog-ui/runs/*.json
apps/blog-ui/uploads/*
!apps/blog-ui/runs/.gitkeep
!apps/blog-ui/uploads/.gitkeep
